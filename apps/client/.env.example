# Only needed when the client and server are deployed on different origins (e.g. client on
# Vercel, server on Railway/Render/Fly) -- Vercel cannot host the persistent WebSocket server.
# Leave unset for local dev: the client falls back to same-origin /ws, which the Vite proxy in
# vite.config.ts forwards to the local backend.
#
# Set this in the Vercel project's Environment Variables (Production), not in a committed file:
# VITE_WS_URL=wss://<your-server-host>/ws
